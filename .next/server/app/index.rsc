me":"relative isolate flex h-screen items-center justify-center overflow-hidden","aria-labelledby":"hero-headline","children":[["$","$L5",null,{"src":"/images/landscaping.jpg","alt":"Your Trusted Partner for Property Solutions","fill":true,"priority":true,"className":"-z-20 object-cover object-center"}],["$","div",null,{"className":"absolute inset-0 -z-10 bg-black/55"}],["$","div",null,{"className":"relative px-4 text-center sm:px-6 lg:px-8","children":[["$","h1",null,{"id":"hero-headline","className":"text-6xl font-black uppercase leading-none tracking-tight text-white drop-shadow-lg sm:text-7xl lg:text-8xl","children":"Your Trusted Partner for Property Solutions"}],["$","p",null,{"className":"mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/90 sm:text-xl","children":"From Plumbing to Landscaping and Everything In Between."}],["$","div",null,{"className":"mt-9 flex flex-col items-center gap-3 sm:flex-row sm:justify-center","children":[["$","a",null,{"href":"#quote","className":"inline-flex justify-center rounded-xl bg-primary px-7 py-3 text-base font-semibold text-white transition-transform duration-200 hover:-translate-y-1","children":"Request a Quote"}],["$","a",null,{"href":"#services","className":"inline-flex justify-center rounded-xl border border-white px-7 py-3 text-base font-semibold text-white transition-colors duration-200 hover:bg-white hover:text-black","children":"View Our Services"}]]}]]}]]}],["$","$L6",null,{"services":[{"id":1,"title":"Plumbing","description":"Reliable plumbing repairs, installations, and maintenance for homes and businesses. Over 20 years of experience in residential and commercial plumbing. Our services include: Pipe repair and replacement, Fixture installation (sinks, toilets, faucets, showers), Water heater installation and repair, Drain cleaning and sewer line service, Leak detection and repair, Bathroom and kitchen plumbing rough-ins, Sump pump installation and maintenance, Water line repair and replacement.","oneLiner":"Reliable plumbing repairs, installations, and maintenance for homes and businesses.","image":"/images/plumbertek.jpg"},{"id":2,"title":"Landscaping","description":"Professional landscaping to transform your outdoor space from the ground up. Full-service landscaping for residential and commercial properties. Our services include: Lawn maintenance and mowing, Garden bed design and planting, Mulching, edging, and seasonal cleanups, Hardscaping (patios, walkways, retaining walls), Grading and drainage solutions, Tree and shrub trimming/removal, Sod installation, Fence installation and repair.","oneLiner":"Professional landscaping to transform your outdoor space from the ground up.","image":"/images/landscapetek.jpg"},{"id":3,"title":"Electric","description":"Safe, up-to-code electrical work for residential and commercial properties. Licensed electrical services for homes and businesses. Our services include: Electrical panel upgrades, Outlet and switch installation/replacement, Interior and exterior lighting, Wiring and rewiring, Circuit breaker repair and replacement, Ceiling fan installation, Generator installation, Code violation corrections and inspections, EV charger installation.","oneLiner":"Safe, up-to-code electrical work for residential and commercial properties.","image":"/images/electrician.jpeg"},{"id":4,"title":"Property Maintenance & Cleanouts","description":"Complete property maintenance, cleanouts, and turnover services — big or small. End-to-end property care for homeowners, landlords, and property managers. Our services include: Full property cleanouts (estate, foreclosure, hoarding), Junk removal and hauling, Rental property turnovers, General handyman repairs, Drywall patching and painting, Pressure washing, Ongoing maintenance packages, Pre-sale property prep, Debris removal and demolition.","oneLiner":"Complete property maintenance, cleanouts, and turnover services — big or small.","image":"/images/bathroom.jpeg"}],"requestQuoteLabel":"Request a Quote"}],"$L7","$L8","$L9"]}],"$La"],null,"$Lb"]}],{},null,false]},null,false],"$Lc",false]],"m":"$undefined","G":["$d",[]],"s":false,"S":true}
