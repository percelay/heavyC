8:["$","section",null,{"id":"about","className":"bg-surface py-20","aria-labelledby":"about-heading","children":["$","div",null,{"className":"mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"id":"about-heading","className":"text-3xl font-semibold text-text-main sm:text-4xl","children":"About"}],["$","div",null,{"className":"mt-3 h-1 w-16 rounded-full bg-primary"}],["$","div",null,{"className":"mt-10 space-y-6 text-lg leading-relaxed text-text-muted","children":[["$","p","0-Heavy C’s Properties",{"children":"Heavy C’s Properties has been serving the community for over 20 years, delivering honest work and quality results on every project—big or small, residential or commercial."}],["$","p","1-Founded by Corbin Ja",{"children":"Founded by Corbin Jackson, Heavy C’s is built on strong family values. Corbin comes from a proud military family; his father and mother served in the Army, and his grandfather was a Marine. That sense of discipline, integrity, and service carries into every job we take on. As a tribute to those who serve, we’re proud to offer discounts to military members and essential workers."}],["$","p","2-Family is at the hea",{"children":"Family is at the heart of everything we do. Corbin’s wife, Morgan, handles sales and marketing, and together they’ve built a company that treats every client like a neighbor. We take pride in honesty, quality, and getting the job done right."}]]}]]}]}]
